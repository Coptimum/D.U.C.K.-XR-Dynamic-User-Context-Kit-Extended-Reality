# Copy this file to .env and fill your Pulsoid token.
# Keep .env local; do not commit it.
PULSOID_TOKEN=

# Input posture stream produced by telemetry/posture-ble/bridge_posture.py --ws-port 8765
POSTURE_WS_URL=ws://127.0.0.1:8765

# Output merged stream served by fusion.mjs
FUSION_WS_HOST=127.0.0.1
FUSION_WS_PORT=9090

# 1 = also emit on posture updates (not only on HR ticks)
FUSION_EMIT_ON_POSTURE=1
